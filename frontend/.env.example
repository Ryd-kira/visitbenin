# frontend/.env.example
# En développement local : laisser vide (le proxy Vite gère)
# En production Vercel : renseigner l'URL Koyeb

# URL de l'API backend (Koyeb)
# Laisser vide en local — Vite proxifie automatiquement vers localhost:3001
VITE_API_URL=

# Exemple production :
# VITE_API_URL=https://visitbenin-api.koyeb.app/api/v1

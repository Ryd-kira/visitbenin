# ══════════════════════════════════════════
# backend/.env.example — VisitBénin
# ══════════════════════════════════════════

# ── Base de données Neon ────────────────────
DATABASE_URL="postgresql://user:password@host-pooler.neon.tech/visitbenin_db?sslmode=require"
DIRECT_URL="postgresql://user:password@host.neon.tech/visitbenin_db?sslmode=require"

# ── Serveur ─────────────────────────────────
PORT=3001
NODE_ENV=production

# ── CORS — URLs de production ───────────────
FRONTEND_URL=https://visitbenin.vercel.app
ADMIN_URL=https://visitbenin-admin.vercel.app

# ── JWT ─────────────────────────────────────
JWT_ACCESS_SECRET=chaine_aleatoire_min_64_caracteres
JWT_REFRESH_SECRET=autre_chaine_aleatoire_min_64_caracteres
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Cloudinary (upload images) ──────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Resend (emails) ─────────────────────────
RESEND_API_KEY=re_your_key
FROM_EMAIL=noreply@visitbenin.bj

# ── Claude API (chatbot Akofa) ──────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here
